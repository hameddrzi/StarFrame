---
const tasks = [
  { icon: '&#128101;', title: 'User Research', desc: 'Interviews, surveys, competitor analysis to understand the target audience' },
  { icon: '&#128100;', title: 'Personas', desc: 'Create fictional user profiles that represent key audience segments' },
  { icon: '&#128221;', title: 'Use Cases', desc: 'Define how users will interact with the system — goals, steps, outcomes' },
  { icon: '&#9989;', title: 'WCAG Analysis', desc: 'Ensure accessibility: contrast, keyboard nav, screen readers, ARIA roles' },
  { icon: '&#128396;', title: 'Wireframe', desc: 'Low-fidelity sketches of layout and content hierarchy' },
  { icon: '&#128241;', title: 'Prototype', desc: 'Interactive mockup in Figma — test flows before writing code' },
  { icon: '&#127912;', title: 'UI Design', desc: 'Colors, typography, spacing, visual identity — the final look' },
  { icon: '&#128269;', title: 'Usability Testing', desc: 'Validate with real users — apply Nielsen heuristics to evaluate' },
];
---

<section id="designer" class="slide slide-designer">
  <div class="designer-container">
    <span class="section-num anim-el">04</span>
    <h2 class="anim-el">What a Web Designer Does</h2>
    <p class="designer-intro anim-el">The essential steps before and during building any interface</p>

    <div class="designer-grid">
      {tasks.map((task, i) => (
        <div class="designer-card anim-el" data-delay={i * 0.08}>
          <div class="designer-card-icon" set:html={task.icon} />
          <div class="designer-card-body">
            <h3>{task.title}</h3>
            <p>{task.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .slide-designer {
    flex-direction: column;
    background: radial-gradient(ellipse at 40% 40%, rgba(168, 130, 255, 0.03) 0%, transparent 50%);
  }

  .designer-container {
    text-align: center;
    max-width: 1100px;
    width: 100%;
  }

  .section-num {
    font-family: var(--font-display);
    font-size: 72px;
    font-weight: 800;
    color: transparent;
    -webkit-text-stroke: 1px rgba(0, 245, 212, 0.15);
    line-height: 1;
    display: block;
    margin-bottom: 8px;
  }

  .designer-container h2 {
    font-size: clamp(32px, 4.5vw, 48px);
    margin-bottom: 8px;
  }

  .designer-intro {
    color: var(--gray);
    font-size: 16px;
    margin-bottom: 48px;
  }

  .designer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  @media (max-width: 900px) {
    .designer-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 500px) {
    .designer-grid { grid-template-columns: 1fr; }
  }

  .designer-card {
    background: rgba(21, 26, 46, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    padding: 24px 18px;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.4s ease, transform 0.4s var(--ease-out-expo);
  }

  .designer-card:hover {
    border-color: rgba(168, 130, 255, 0.25);
    transform: translateY(-4px);
  }

  .designer-card-icon {
    font-size: 28px;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(168, 130, 255, 0.1);
    border-radius: 12px;
    flex-shrink: 0;
  }

  .designer-card-body h3 {
    font-size: 14px;
    color: #A882FF;
    margin-bottom: 6px;
    font-weight: 700;
  }

  .designer-card-body p {
    font-size: 12px;
    color: var(--gray);
    line-height: 1.6;
  }
</style>
