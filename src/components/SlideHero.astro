---
const timeline = [
  { year: '1398 (2019)', text: 'Photoshop course at Sharif University — also started photography', i18n: 'hero.tl1' },
  { year: '1398–1399', text: 'Joined PhotoKit, a mobile app startup — saw the magic of building products people can see and touch', i18n: 'hero.tl2' },
  { year: 'During that period', text: 'Started studying Marketing at university — driven by love for human connection', i18n: 'hero.tl3' },
  { year: '1399–1400', text: 'Built a game with Godot engine — first real product creation experience', i18n: 'hero.tl4' },
];
---

<section id="hero" class="slide slide-hero">
  <canvas id="particle-canvas"></canvas>

  <div class="hero-bg-text" aria-hidden="true">HD</div>

  <div class="hero-content">
    <div class="hero-tag anim-el">Frontend Developer</div>
    <h1 class="hero-name anim-el">
      <span class="name-line">Hamed</span>
      <span class="name-line">Darzi</span>
    </h1>
    <p class="hero-sub anim-el" data-i18n="hero.sub">Born January 1999 &middot; Iran &rarr; Italy</p>

    <div class="hero-divider anim-el"></div>

    <div class="timeline">
      {timeline.map((item, i) => (
        <div class="tl-item anim-el" data-delay={i * 0.15}>
          <div class="tl-dot-wrap">
            <span class="tl-dot" />
            {i < timeline.length - 1 && <span class="tl-line" />}
          </div>
          <div class="tl-content">
            <span class="tl-year">{item.year}</span>
            <p data-i18n={item.i18n}>{item.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="scroll-hint anim-el">
    <span data-i18n="hero.scroll">Scroll</span>
    <svg width="16" height="24" viewBox="0 0 16 24" fill="none">
      <rect x="1" y="1" width="14" height="22" rx="7" stroke="var(--gray)" stroke-width="1.5"/>
      <circle class="scroll-dot" cx="8" cy="8" r="2" fill="var(--cyan)">
        <animate attributeName="cy" values="8;16;8" dur="2s" repeatCount="indefinite"/>
      </circle>
    </svg>
  </div>
</section>

<style>
  .slide-hero {
    flex-direction: column;
    justify-content: center;
    position: relative;
    background: radial-gradient(ellipse at 30% 20%, rgba(0, 245, 212, 0.04) 0%, transparent 50%),
                radial-gradient(ellipse at 70% 80%, rgba(255, 183, 3, 0.02) 0%, transparent 50%);
  }

  #particle-canvas {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hero-bg-text {
    position: absolute;
    font-family: var(--font-display);
    font-size: clamp(250px, 35vw, 600px);
    font-weight: 800;
    color: transparent;
    -webkit-text-stroke: 1px rgba(0, 245, 212, 0.04);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    user-select: none;
    z-index: 0;
    line-height: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 720px;
  }

  .hero-tag {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cyan);
    border: 1px solid rgba(0, 245, 212, 0.25);
    padding: 6px 20px;
    border-radius: 100px;
    margin-bottom: 28px;
  }

  .hero-name {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    margin-bottom: 16px;
  }

  .name-line {
    display: block;
    font-size: clamp(56px, 10vw, 110px);
    font-weight: 800;
    line-height: 1.05;
    background: linear-gradient(135deg, var(--white) 0%, var(--cyan) 70%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: clamp(14px, 2vw, 18px);
    color: var(--gray);
    font-weight: 300;
    letter-spacing: 0.08em;
    margin-bottom: 40px;
  }

  .hero-divider {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, var(--cyan), var(--amber));
    margin: 0 auto 40px;
    border-radius: 2px;
  }

  /* TIMELINE */
  .timeline {
    text-align: left;
    max-width: 520px;
    margin: 0 auto;
  }

  .tl-item {
    display: flex;
    gap: 18px;
    position: relative;
  }

  .tl-dot-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    padding-top: 4px;
  }

  .tl-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid var(--cyan);
    background: var(--bg);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    transition: background 0.5s ease, box-shadow 0.5s ease;
  }

  .slide-hero.is-active .tl-dot {
    background: var(--cyan);
    box-shadow: 0 0 8px rgba(0, 245, 212, 0.4);
  }

  .tl-line {
    width: 2px;
    flex: 1;
    background: linear-gradient(to bottom, var(--cyan), rgba(0, 245, 212, 0.1));
    min-height: 20px;
  }

  .tl-content {
    padding-bottom: 28px;
  }

  .tl-year {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 700;
    color: var(--cyan);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 4px;
    background: var(--cyan-dim);
    padding: 2px 10px;
    border-radius: 4px;
  }

  .tl-content p {
    font-size: 14px;
    color: var(--gray);
    line-height: 1.6;
  }

  /* SCROLL HINT */
  .scroll-hint {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    z-index: 2;
  }

  .scroll-hint span {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gray);
  }
</style>
