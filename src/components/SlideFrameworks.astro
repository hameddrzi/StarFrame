---
const frameworks = [
  { icon: '&#9883;', name: 'React', desc: 'UI Library by Meta, component-based', badge: 'Library', color: '#61DAFB', idx: 1 },
  { icon: '&#9650;', name: 'Angular', desc: 'Full framework by Google, opinionated', badge: 'Framework', color: '#DD0031', idx: 2 },
  { icon: '&#9698;', name: 'Vue.js', desc: 'Progressive framework, gentle learning curve', badge: 'Progressive', color: '#42b883', idx: 3 },
  { icon: '&#9654;', name: 'Next.js', desc: 'React-based, SSR & SSG powerhouse', badge: 'Full-stack', color: '#ffffff', idx: 4 },
  { icon: '&#9733;', name: 'Nuxt.js', desc: 'Vue-based full-stack framework', badge: 'Full-stack', color: '#00DC82', idx: 5 },
  { icon: '&#10038;', name: 'Astro', desc: 'Content-first, ship less JS', badge: 'Static', color: '#FF5D01', idx: 6 },
  { icon: '&#10047;', name: 'Svelte', desc: 'Compile-time magic, no virtual DOM', badge: 'Compiler', color: '#FF3E00', idx: 7 },
  { icon: '&#9743;', name: 'Expo / React Native', desc: 'Cross-platform mobile with React', badge: 'Mobile', color: '#000020', idx: 8 },
];
---

<section id="frameworks" class="slide slide-frameworks">
  <div class="fw-container">
    <span class="section-num anim-el">03</span>
    <h2 class="anim-el">Frontend Ecosystem</h2>
    <p class="fw-intro anim-el" data-i18n="fw.intro">The tools shaping modern web development — click a card to learn more</p>

    <div class="fw-grid">
      {frameworks.map((fw, i) => (
        <div
          class="fw-card anim-el"
          data-delay={i * 0.08}
          style={`--accent: ${fw.color};`}
          data-popup-idx={fw.idx}
          data-popup-badge={fw.badge}
        >
          <div class="fw-card-inner">
            <div class="fw-icon" set:html={fw.icon} />
            <h3>{fw.name}</h3>
            <p data-i18n={`fw.desc${fw.idx}`}>{fw.desc}</p>
            <span class="fw-badge">{fw.badge}</span>
          </div>
          <div class="fw-card-shine" />
        </div>
      ))}
    </div>
  </div>
</section>


<style>
  .slide-frameworks {
    flex-direction: column;
  }

  .fw-container {
    text-align: center;
    max-width: 1100px;
    width: 100%;
  }

  .section-num {
    font-family: var(--font-display);
    font-size: 72px;
    font-weight: 800;
    color: transparent;
    -webkit-text-stroke: 1px rgba(0, 245, 212, 0.15);
    line-height: 1;
    display: block;
    margin-bottom: 8px;
  }

  .fw-container h2 {
    font-size: clamp(32px, 4.5vw, 48px);
    margin-bottom: 8px;
  }

  .fw-intro {
    color: var(--gray);
    font-size: 16px;
    margin-bottom: 48px;
  }

  .fw-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }

  @media (max-width: 900px) {
    .fw-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
  }

  @media (max-width: 500px) {
    .fw-grid { grid-template-columns: 1fr; }
  }

  .fw-card {
    position: relative;
    border-radius: 18px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.45s var(--ease-out-expo), box-shadow 0.45s ease;
  }

  .fw-card-inner {
    position: relative;
    z-index: 1;
    background: rgba(21, 26, 46, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 18px;
    padding: 28px 22px;
    text-align: left;
    height: 100%;
    transition: border-color 0.4s ease;
  }

  .fw-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  }

  .fw-card:hover .fw-card-inner {
    border-color: var(--accent, var(--cyan));
  }

  .fw-card-shine {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: radial-gradient(circle at 50% 0%, var(--accent, var(--cyan)), transparent 60%);
    opacity: 0;
    transition: opacity 0.4s ease;
    filter: blur(40px);
  }

  .fw-card:hover .fw-card-shine {
    opacity: 0.08;
  }

  .fw-icon {
    font-size: 30px;
    margin-bottom: 14px;
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .fw-card h3 {
    font-size: 17px;
    margin-bottom: 6px;
    color: var(--white);
  }

  .fw-card p {
    font-size: 13px;
    color: var(--gray);
    line-height: 1.5;
    margin-bottom: 14px;
  }

  .fw-badge {
    display: inline-block;
    padding: 3px 12px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.05em;
    background: var(--cyan-dim);
    color: var(--cyan);
    border: 1px solid rgba(0, 245, 212, 0.15);
  }

</style>

<script>
  import { translations } from '../i18n/translations';

  const popup = document.getElementById('fw-popup')!;
  const popupTitle = document.getElementById('popup-title')!;
  const popupText = document.getElementById('popup-text')!;
  const popupBadge = document.getElementById('popup-badge')!;
  const popupClose = document.getElementById('popup-close')!;

  function getLang(): string {
    return document.documentElement.dataset.lang || 'en';
  }

  // Open popup on card click
  document.querySelectorAll<HTMLElement>('.fw-card').forEach((card) => {
    card.addEventListener('click', () => {
      const idx = card.dataset.popupIdx || '1';
      const lang = getLang();
      popupTitle.innerHTML = translations[`fw.popup${idx}_title`]?.[lang] || '';
      popupText.innerHTML = translations[`fw.popup${idx}_text`]?.[lang] || '';
      popupBadge.textContent = card.dataset.popupBadge || '';
      popup.classList.add('open');
    });
  });

  // Close popup
  popupClose.addEventListener('click', () => popup.classList.remove('open'));
  popup.addEventListener('click', (e) => {
    if (e.target === popup) popup.classList.remove('open');
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') popup.classList.remove('open');
  });
</script>
