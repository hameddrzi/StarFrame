---

<section id="university" class="slide slide-university">
  <div class="uni-inner">
    <div class="uni-left">
      <span class="section-num anim-el">02</span>
      <h2 class="anim-el">Universit&agrave; degli Studi<br>di Torino</h2>
      <p class="uni-sub anim-el">Full Stack Development Course</p>

      <div class="curriculum-cards">
        <div class="cur-card anim-el">
          <div class="cur-icon">&#9883;</div>
          <h4>Frontend</h4>
          <p data-i18n="uni.fe_desc">TypeScript + React using the <strong>MVVM</strong> pattern — building reactive, component-driven interfaces.</p>
        </div>
        <div class="cur-card backend-card anim-el">
          <div class="cur-icon">&#9881;</div>
          <h4>Backend</h4>
          <p data-i18n="uni.be_desc">Java Spring Boot following the <strong>MVC</strong> pattern — RESTful APIs, layered architecture.</p>
        </div>
      </div>
    </div>

    <div class="uni-right anim-el">
      <div class="galaxy" id="galaxy">
        <!-- Stars background -->
        <div class="galaxy-stars"></div>

        <!-- Orbit rings -->
        <div class="orbit-ring ring-1"></div>
        <div class="orbit-ring ring-2"></div>
        <div class="orbit-ring ring-3"></div>

        <!-- Center sun -->
        <div class="galaxy-center">
          <div class="center-glow"></div>
          <span>Frontend</span>
        </div>

        <!-- Inner orbit — HTML & CSS (faster, closer) -->
        <div class="orbit orbit-inner">
          <div class="planet" style="--color: #E34C26; --glow: rgba(227,76,38,0.4);">
            <div class="planet-body">
              <span class="planet-icon">&lt;/&gt;</span>
              <span class="planet-name">HTML</span>
            </div>
          </div>
          <div class="planet" style="--color: #264DE4; --glow: rgba(38,77,228,0.4);">
            <div class="planet-body">
              <span class="planet-icon">{ }</span>
              <span class="planet-name">CSS</span>
            </div>
          </div>
        </div>

        <!-- Middle orbit — JavaScript -->
        <div class="orbit orbit-mid">
          <div class="planet" style="--color: #F7DF1E; --glow: rgba(247,223,30,0.35);">
            <div class="planet-body">
              <span class="planet-icon">JS</span>
              <span class="planet-name">JavaScript</span>
            </div>
          </div>
        </div>

        <!-- Outer orbit — TypeScript -->
        <div class="orbit orbit-outer">
          <div class="planet" style="--color: #3178C6; --glow: rgba(49,120,198,0.35);">
            <div class="planet-body">
              <span class="planet-icon">TS</span>
              <span class="planet-name">TypeScript</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .slide-university {
    background: radial-gradient(ellipse at 70% 30%, rgba(0, 245, 212, 0.03) 0%, transparent 50%);
  }

  .uni-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    max-width: 1100px;
    width: 100%;
    align-items: center;
  }

  @media (max-width: 900px) {
    .uni-inner { grid-template-columns: 1fr; gap: 40px; }
  }

  .section-num {
    font-family: var(--font-display);
    font-size: 72px;
    font-weight: 800;
    color: transparent;
    -webkit-text-stroke: 1px rgba(0, 245, 212, 0.15);
    line-height: 1;
    display: block;
    margin-bottom: 8px;
  }

  .uni-left h2 {
    font-size: clamp(28px, 4vw, 46px);
    line-height: 1.15;
    margin-bottom: 8px;
  }

  .uni-sub {
    font-size: 16px;
    color: var(--amber);
    font-weight: 500;
    margin-bottom: 32px;
  }

  .curriculum-cards {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .cur-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    padding: 22px;
    display: flex;
    gap: 16px;
    align-items: flex-start;
    transition: border-color 0.4s ease;
  }

  .cur-card:hover {
    border-color: rgba(0, 245, 212, 0.2);
  }

  .backend-card:hover {
    border-color: rgba(255, 183, 3, 0.2);
  }

  .cur-icon {
    font-size: 28px;
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--cyan-dim);
    border-radius: 12px;
  }

  .backend-card .cur-icon {
    background: var(--amber-dim);
  }

  .cur-card h4 {
    font-size: 16px;
    color: var(--cyan);
    margin-bottom: 4px;
  }

  .backend-card h4 {
    color: var(--amber);
  }

  .cur-card p {
    font-size: 13px;
    color: var(--gray);
    line-height: 1.6;
  }

  .cur-card strong {
    color: var(--white);
  }

  /* ─── GALAXY ─── */
  .galaxy {
    position: relative;
    width: 420px;
    height: 420px;
    margin: 0 auto;
  }

  @media (max-width: 500px) {
    .galaxy { width: 300px; height: 300px; }
  }

  /* Tiny star dots */
  .galaxy-stars {
    position: absolute;
    inset: -20px;
    background-image:
      radial-gradient(1px 1px at 15% 25%, rgba(255,255,255,0.25), transparent),
      radial-gradient(1px 1px at 75% 15%, rgba(255,255,255,0.2), transparent),
      radial-gradient(1px 1px at 40% 80%, rgba(255,255,255,0.15), transparent),
      radial-gradient(1px 1px at 85% 65%, rgba(255,255,255,0.2), transparent),
      radial-gradient(1px 1px at 55% 45%, rgba(255,255,255,0.12), transparent),
      radial-gradient(1.5px 1.5px at 20% 70%, rgba(0,245,212,0.15), transparent),
      radial-gradient(1.5px 1.5px at 90% 35%, rgba(255,183,3,0.1), transparent),
      radial-gradient(1px 1px at 10% 90%, rgba(255,255,255,0.15), transparent),
      radial-gradient(1px 1px at 60% 10%, rgba(255,255,255,0.18), transparent),
      radial-gradient(1px 1px at 30% 55%, rgba(255,255,255,0.12), transparent);
    pointer-events: none;
    z-index: 0;
    animation: twinkle 4s ease-in-out infinite alternate;
  }

  @keyframes twinkle {
    0% { opacity: 0.6; }
    100% { opacity: 1; }
  }

  /* Orbit rings */
  .orbit-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(0, 245, 212, 0.07);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  .slide-university.is-active .orbit-ring {
    opacity: 1;
  }

  .ring-1 {
    width: 55%;
    height: 55%;
    border-color: rgba(0, 245, 212, 0.08);
    transition-delay: 0.3s;
  }
  .ring-2 {
    width: 72%;
    height: 72%;
    border-color: rgba(0, 245, 212, 0.06);
    border-style: dashed;
    transition-delay: 0.5s;
  }
  .ring-3 {
    width: 92%;
    height: 92%;
    border-color: rgba(0, 245, 212, 0.04);
    transition-delay: 0.7s;
  }

  /* Center "sun" */
  .galaxy-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0, 245, 212, 0.15) 0%, rgba(0, 245, 212, 0.03) 70%);
    border: 2px solid var(--cyan);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }

  .galaxy-center span {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    color: var(--cyan);
    z-index: 2;
    position: relative;
  }

  .center-glow {
    position: absolute;
    inset: -20px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0, 245, 212, 0.12) 0%, transparent 70%);
    z-index: 0;
    pointer-events: none;
  }

  @keyframes center-pulse {
    0%, 100% {
      box-shadow: 0 0 20px rgba(0, 245, 212, 0.15), 0 0 60px rgba(0, 245, 212, 0.05);
    }
    50% {
      box-shadow: 0 0 30px rgba(0, 245, 212, 0.25), 0 0 80px rgba(0, 245, 212, 0.1);
    }
  }

  .slide-university.is-active .galaxy-center {
    animation: center-pulse 3s ease-in-out infinite;
  }

  /* Orbits — rotating containers */
  .orbit {
    position: absolute;
    top: 50%;
    left: 50%;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  .slide-university.is-active .orbit {
    opacity: 1;
  }

  .orbit-inner {
    width: 55%;
    height: 55%;
    animation: spin 20s linear infinite;
    transition-delay: 0.4s;
  }

  .orbit-mid {
    width: 72%;
    height: 72%;
    animation: spin 30s linear infinite reverse;
    transition-delay: 0.6s;
  }

  .orbit-outer {
    width: 92%;
    height: 92%;
    animation: spin 40s linear infinite;
    transition-delay: 0.8s;
  }

  /* Pause orbiting on hover */
  .galaxy:hover .orbit {
    animation-play-state: paused;
  }

  @keyframes spin {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to   { transform: translate(-50%, -50%) rotate(360deg); }
  }

  /* Planets */
  .planet {
    position: absolute;
    pointer-events: auto;
    /* Position on the orbit circle edge using --start angle */
    top: 50%;
    left: 50%;
    transform: rotate(var(--start)) translateX(calc(50% + 0px)) rotate(calc(-1 * var(--start)));
    /* Correct position: place on the edge */
  }

  /* Position planets using top/left + transform for orbit edge */
  .orbit-inner .planet:nth-child(1) {
    top: 0%; left: 50%;
    transform: translate(-50%, -50%);
  }
  .orbit-inner .planet:nth-child(2) {
    bottom: 0%; top: auto; left: 50%;
    transform: translate(-50%, 50%);
  }
  .orbit-mid .planet:nth-child(1) {
    top: 50%; left: 100%;
    transform: translate(-50%, -50%);
  }
  .orbit-outer .planet:nth-child(1) {
    top: 15%; left: 15%;
    transform: translate(-50%, -50%);
  }
  .orbit-outer .planet:nth-child(2) {
    bottom: 15%; top: auto; right: 15%; left: auto;
    transform: translate(50%, 50%);
  }

  .planet-body {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(10, 14, 26, 0.9);
    border: 2px solid var(--color);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1px;
    box-shadow: 0 0 15px var(--glow), inset 0 0 8px rgba(255,255,255,0.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    cursor: default;
    position: relative;
    z-index: 2;
  }

  /* Counter-rotate planet bodies so text stays upright */
  .orbit-inner .planet-body {
    animation: counter-spin 20s linear infinite;
  }
  .orbit-mid .planet-body {
    animation: counter-spin 30s linear infinite reverse;
  }
  .orbit-outer .planet-body {
    animation: counter-spin 40s linear infinite;
  }

  .galaxy:hover .planet-body {
    animation-play-state: paused;
  }

  @keyframes counter-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(-360deg); }
  }

  .planet-body:hover {
    transform: scale(1.2);
    box-shadow: 0 0 25px var(--glow), 0 0 50px var(--glow);
  }

  .planet-icon {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 800;
    color: var(--color);
    line-height: 1;
  }

  .planet-name {
    font-family: var(--font-body);
    font-size: 8px;
    font-weight: 600;
    color: var(--color);
    letter-spacing: 0.03em;
    white-space: nowrap;
    opacity: 0.85;
    line-height: 1;
  }

  /* Comet trail effect on planets */
  .planet-body::after {
    content: '';
    position: absolute;
    width: 20px;
    height: 2px;
    background: linear-gradient(90deg, var(--color), transparent);
    top: 50%;
    right: -18px;
    transform: translateY(-50%);
    opacity: 0.3;
    border-radius: 2px;
  }
</style>
