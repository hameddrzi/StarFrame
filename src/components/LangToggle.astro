<button id="lang-toggle" class="lang-toggle" aria-label="Toggle language">
  <span class="lang-label" id="lang-label">FA</span>
</button>

<style>
  .lang-toggle {
    position: fixed;
    top: 28px;
    right: 80px;
    z-index: 1001;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(21, 26, 46, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.3s ease, transform 0.3s ease, background 0.3s ease;
  }

  .lang-toggle:hover {
    border-color: rgba(0, 245, 212, 0.4);
    transform: scale(1.1);
    background: rgba(0, 245, 212, 0.08);
  }

  .lang-label {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    color: var(--cyan);
    letter-spacing: 0.04em;
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .lang-toggle {
      top: 16px;
      right: 52px;
      width: 38px;
      height: 38px;
    }
    .lang-label { font-size: 11px; }
  }
</style>
